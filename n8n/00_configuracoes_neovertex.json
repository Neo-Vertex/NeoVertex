    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Tabela de memória do agente (compatível com memoryPostgresChat do langchain)\nCREATE TABLE IF NOT EXISTS nv_historico_mensagens (\n  id          SERIAL PRIMARY KEY,\n  session_id  TEXT NOT NULL,\n  message     JSONB NOT NULL\n);\n\nCREATE INDEX IF NOT EXISTS idx_nv_historico_mensagens_session_id\n  ON nv_historico_mensagens (session_id);\n\n-- Fila de mensagens recebidas (debounce)\nCREATE TABLE IF NOT EXISTS nv_fila_mensagens (\n  id         SERIAL PRIMARY KEY,\n  telefone   TEXT NOT NULL,\n  conteudo   TEXT NOT NULL,\n  criado_em  TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\nCREATE INDEX IF NOT EXISTS idx_nv_fila_mensagens_telefone\n  ON nv_fila_mensagens (telefone);\n\nCREATE INDEX IF NOT EXISTS idx_nv_fila_mensagens_criado_em\n  ON nv_fila_mensagens (criado_em);\n\n-- Status de atendimento por contato (lock + flags)\nCREATE TABLE IF NOT EXISTS nv_status_atendimento (\n  telefone        TEXT PRIMARY KEY,\n  lock_conversa   BOOLEAN NOT NULL DEFAULT FALSE,\n  agente_pausado  BOOLEAN NOT NULL DEFAULT FALSE,\n  atualizado_em   TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\n-- CRM leve - leads que passaram pelo agente\nCREATE TABLE IF NOT EXISTS nv_leads (\n  id                SERIAL PRIMARY KEY,\n  telefone          TEXT NOT NULL,\n  nome              TEXT,\n  empresa           TEXT,\n  area_interesse    TEXT,\n  motivo_escala     TEXT,\n  horario_sugerido  TEXT,\n  criado_em         TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\nCREATE INDEX IF NOT EXISTS idx_nv_leads_telefone\n  ON nv_leads (telefone);\n",
        "options": {}
      },
