    {
      "id": "74442bd9-da82-48cd-9c56-73f5dacbdc61",
      "name": "cotacao_binance",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        620,
        220
      ],
      "parameters": {
        "toolDescription": "Retorna preço atual e variação de 24h de uma cripto na Binance. Informe o símbolo base em maiúsculas (ex.: BTC, ETH, SOL, SUI, XRP).",
        "method": "GET",
        "url": "https://api.binance.com/api/v3/ticker/24hr?symbol={symbol}USDT",
        "placeholderDefinitions": {
          "values": [
            {
              "name": "symbol",
              "description": "Símbolo base da cripto em maiúsculas, ex.: BTC",
              "type": "string"
            }
          ]
        }
      }
    },
    {
