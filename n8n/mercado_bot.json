      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        780,
        360
      ],
      "parameters": {
        "toolDescription": "Retorna a ENTRADA LÍQUIDA do dia de uma cripto (compra agressiva menos venda agressiva, em USDT) + % de compra, variação e volume. Use para perguntas sobre entrada, fluxo, quanto entrou/saiu, pressão compradora ou baleia. Informe o símbolo base, ex.: SUI.",
        "method": "GET",
        "url": "https://n8n.neovertexia.com/webhook/entrada-liquida-865e05c7?symbol={symbol}",
        "placeholderDefinitions": {
          "values": [
            {
              "name": "symbol",
              "description": "Símbolo base da cripto em maiúsculas, ex.: SUI",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "01bfa08a-1810-4743-bd31-3ce17fe4f3f6",
      "name": "grandes_negociacoes",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        780,
        520
      ],
      "parameters": {
        "toolDescription": "Retorna a maior COMPRA e a maior VENDA agressiva (em USDT) entre as negociações RECENTES de uma cripto (não o dia inteiro, por limite da API pública). Use para 'maior compra', 'maior venda', maior ordem ou grande trade/baleia. Informe o símbolo base, ex.: BTC.",
        "method": "GET",
        "url": "https://n8n.neovertexia.com/webhook/grandes-trades-91572e52?symbol={symbol}",
        "placeholderDefinitions": {
          "values": [
            {
              "name": "symbol",
              "description": "Símbolo base da cripto em maiúsculas, ex.: BTC",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "7a5ed98f-b161-43d4-b24b-a075a38962cb",
      "name": "criar_alerta",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        780,
        680
      ],
      "parameters": {
        "toolDescription": "Cria um alerta de mercado para o usuário ser notificado. Use quando pedirem para ser avisados quando um ativo atingir um preço (kind=price) ou um prêmio Coinbase em % (kind=institutional).",
        "method": "POST",
        "url": "https://n8n.neovertexia.com/webhook/criar-alerta-96132836",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"kind\":\"{kind}\",\"symbol\":\"{symbol}\",\"operator\":\"{operator}\",\"target\":\"{target}\"}",
        "placeholderDefinitions": {
          "values": [
            {
              "name": "kind",
              "description": "'price' para alvo de preço ou 'institutional' para prêmio Coinbase",
              "type": "string"
            },
            {
              "name": "symbol",
              "description": "símbolo base da cripto em maiúsculas, ex.: BTC",
              "type": "string"
            },
            {
              "name": "operator",
              "description": "'gte' (atingir ou acima) ou 'lte' (atingir ou abaixo)",
              "type": "string"
            },
            {
              "name": "target",
              "description": "número alvo: preço em USDT (price) ou percentual (institutional)",
              "type": "string"
            }
          ]
        }
      }
    }
