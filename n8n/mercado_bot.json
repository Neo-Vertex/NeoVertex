      },
      "credentials": {
        "postgres": {
          "id": "aJKw8OGZ2pzPHt0E",
          "name": "NeoVertex Postgres"
        }
      }
    },
    {
      "id": "3b87f767-eced-40b6-a4e7-277dcdda37bb",
      "name": "Refletir",
      "type": "@n8n/n8n-nodes-langchain.toolThink",
      "typeVersion": 1.1,
      "position": [
        470,
        220
      ],
      "parameters": {
        "description": "Use para raciocinar antes de responder sobre mercado."
      }
    },
    {
      "id": "74442bd9-da82-48cd-9c56-73f5dacbdc61",
      "name": "cotacao_binance",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        620,
        220
      ],
      "parameters": {
        "toolDescription": "Retorna preço atual e variação de 24h de uma cripto na Binance. Informe o símbolo base em maiúsculas (ex.: BTC, ETH, SOL, SUI, XRP).",
        "method": "GET",
        "url": "https://api.binance.com/api/v3/ticker/24hr?symbol={symbol}USDT",
        "placeholderDefinitions": {
          "values": [
            {
              "name": "symbol",
              "description": "Símbolo base da cripto em maiúsculas, ex.: BTC",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "fdc27202-d14a-4a83-945b-7ef24786c607",
      "name": "Registrar chat",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        280,
        200
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO telegram_subscribers (chat_id, label, is_admin) VALUES ($1, 'admin', true) ON CONFLICT (chat_id) DO NOTHING",
        "options": {
          "queryReplacement": "={{ $json.message.chat.id }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "aJKw8OGZ2pzPHt0E",
          "name": "NeoVertex Postgres"
        }
      }
    }
