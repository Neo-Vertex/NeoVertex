    {
      "id": "93fda6f8-ea0a-4c0a-8403-ae0b0c3861b0",
      "name": "Agente Mercado",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
      "position": [
        280,
        0
      ],
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.message.text }}",
        "options": {
          "systemMessage": "Você é o assistente de mercado da Neo Vertex no Telegram. Responde em português, conciso e direto, sobre criptomoedas e ativos. Para PREÇO ou variação, use SEMPRE a ferramenta 'cotacao_binance' e nunca invente números. Para fundamentos/projeto de um ativo, explique de forma clara e curta. Sem emoji decorativo. A watchlist principal é BTC, ETH, SOL, SUI, XRP. Se pedirem algo fora de mercado, redirecione gentilmente."
        }
      }
    },
    {
      "id": "1b93fad3-38bf-4dde-a7ff-d6f5504bfe0f",
      "name": "Responder Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        620,
        0
      ],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "={{ $json.output }}",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "JshBGRby8HIJowz3",
          "name": "Telegram NeoVertex Mercado"
        }
      },
      "webhookId": "703fa33f-afac-4aaa-a4e7-e6dd93098215"
    },
    {
