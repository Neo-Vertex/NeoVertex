    {
      "parameters": {
        "jsCode": "// Detecta mensagens encavaladas. Se chegou mensagem nova depois desta\n// execução (id maior do que a última do payload original), aborta.\nconst itens = $input.all();\nif (itens.length === 0) return [];\n\nconst ultimoIdFila = Math.max(...itens.map(i => Number(i.json.id) || 0));\n\n// Recupera o id da mensagem que iniciou esta execução\nconst inicial = $('Enfileirar mensagem').first();\nconst idInicial = inicial && inicial.json && inicial.json.id ? Number(inicial.json.id) : 0;\n\n// Se a última mensagem na fila tem id maior do que a inicial e não somos nós\n// o último item, deixa a execução mais recente cuidar de tudo.\nif (ultimoIdFila > idInicial) {\n  // Mensagem encavalada — sai sem produzir itens\n  return [];\n}\n\n// Concatena conteúdo em uma única string para passar ao agente\nconst mensagemConcat = itens\n  .map(i => i.json.conteudo)\n  .filter(Boolean)\n  .join('\\n');\n\nreturn [{ json: { mensagem: mensagemConcat, total_itens: itens.length, telefone: itens[0].json.telefone } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1580,
        700
      ],
      "id": "10000000-0007-4007-8007-000000000007",
