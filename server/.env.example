# Backend NeoVertex API (Express + PostgreSQL)

# Conexão PostgreSQL (o MESMO banco usado pelo n8n)
DATABASE_URL=postgres://usuario:senha@host:5432/neovertex
# true se o Postgres exigir SSL (provedores gerenciados normalmente exigem)
DB_SSL=false

# Segredo para assinar os tokens JWT (gere um valor aleatório forte)
JWT_SECRET=troque-isto-por-um-segredo-forte

# Porta do servidor (Coolify mapeia para a porta interna)
PORT=3001

# Token do CryptoPanic para a aba Notícias (opcional; plano free foi descontinuado)
CRYPTOPANIC_TOKEN=
